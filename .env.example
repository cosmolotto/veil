# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Mobile app (EXPO_PUBLIC_ prefix = exposed to client bundle) ───────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_URL=https://your-api.railway.app

# ── RevenueCat ────────────────────────────────────────────────────────────
# Get from app.revenuecat.com → Project → API Keys
REVENUECAT_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx
# Android public SDK key (different from Apple key)
REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx

# ── API server ────────────────────────────────────────────────────────────
PORT=3001
