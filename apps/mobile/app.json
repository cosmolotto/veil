{
  "expo": {
    "name": "VEIL",
    "slug": "veil",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "description": "A private reflection network where identity stays hidden until genuine emotional connection is formed.",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#0F0820"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0820"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.morvenempire.veil",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0820"
      },
      "package": "com.morvenempire.veil",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B5CF6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "veil",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "25f9e322-d339-4040-bb2f-95cb89d39438"
      }
    },
    "owner": "morven"
  }
}
