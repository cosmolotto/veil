{
  "name": "mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "release:check": "node ./scripts/check-release-env.mjs && expo config --type public > /dev/null",
    "build:android:preview": "pnpm run release:check && eas build --platform android --profile preview",
    "build:android:production": "pnpm run release:check && eas build --platform android --profile production",
    "submit:android:production": "pnpm run release:check && eas submit --platform android --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.56.0",
    "@veil/shared": "workspace:*",
    "expo": "~55.0.14",
    "expo-constants": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.12",
    "expo-notifications": "~55.0.18",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.14",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.21.2",
    "tailwindcss": "^3.4.14",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.2.14",
    "metro": "0.83.5",
    "typescript": "~5.9.3"
  }
}
